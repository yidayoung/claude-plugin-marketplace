{
  "name": "@claude-marketplace/plugin",
  "displayName": "Claude Plugin Marketplace",
  "description": "Claude Code 插件市场：浏览、安装、管理 Claude Code 技能插件",
  "version": "0.1.0",
  "publisher": "gdd-team",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "plugin",
    "marketplace",
    "skills"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-marketplace-sidebar",
          "title": "Plugin Market",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "claude-marketplace-sidebar": [
        {
          "id": "claudePluginMarketplaceSidebar",
          "type": "webview",
          "name": "插件市场"
        }
      ]
    },
    "commands": [
      {
        "command": "claudePluginMarketplace.open",
        "title": "打开插件市场面板",
        "icon": "$(extensions)"
      },
      {
        "command": "claudePluginMarketplace.refresh",
        "title": "刷新插件列表",
        "icon": "$(refresh)"
      },
      {
        "command": "claudePluginMarketplace.addMarketplace",
        "title": "添加插件市场",
        "icon": "$(add)"
      },
      {
        "command": "claudePluginMarketplace.removeMarketplace",
        "title": "删除插件市场"
      },
      {
        "command": "claudePluginMarketplace.refreshMarketplace",
        "title": "刷新插件市场"
      },
      {
        "command": "claudePluginMarketplace.installPlugin",
        "title": "安装插件"
      },
      {
        "command": "claudePluginMarketplace.uninstallPlugin",
        "title": "卸载插件"
      },
      {
        "command": "claudePluginMarketplace.updatePlugin",
        "title": "更新插件",
        "icon": "$(sync)"
      },
      {
        "command": "claudePluginMarketplace.showPluginDetails",
        "title": "查看插件详情"
      },
      {
        "command": "claudePluginMarketplace.enablePlugin",
        "title": "启用插件"
      },
      {
        "command": "claudePluginMarketplace.disablePlugin",
        "title": "禁用插件"
      },
      {
        "command": "claudePluginMarketplace.searchPlugins",
        "title": "搜索插件",
        "icon": "$(search)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build-webview": "cd ../webview-app && npm run build && rm -rf ../vscode-extension/webview/dist && mkdir -p ../vscode-extension/webview/dist && cp -r dist/* ../vscode-extension/webview/dist/"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.80.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
