{
  "name": "claude-plugin-marketplace",
  "displayName": "Claude Plugin Marketplace",
  "description": "%extension.description%",
  "version": "0.1.0",
  "publisher": "yidayoung",
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/yidayoung/claude-plugin-marketplace"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "plugin",
    "marketplace",
    "skills"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-marketplace-sidebar",
          "title": "%view.containers.title%",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "claude-marketplace-sidebar": [
        {
          "id": "claudePluginMarketplaceSidebar",
          "type": "webview",
          "name": "%view.sidebar.name%"
        }
      ]
    },
    "commands": [
      {
        "command": "claudePluginMarketplace.refresh",
        "title": "%command.refresh.title%",
        "icon": "$(refresh)"
      },
      {
        "command": "claudePluginMarketplace.addMarketplace",
        "title": "%command.addMarketplace.title%",
        "icon": "$(add)"
      },
      {
        "command": "claudePluginMarketplace.removeMarketplace",
        "title": "%command.removeMarketplace.title%"
      },
      {
        "command": "claudePluginMarketplace.refreshMarketplace",
        "title": "%command.refreshMarketplace.title%"
      },
      {
        "command": "claudePluginMarketplace.installPlugin",
        "title": "%command.installPlugin.title%"
      },
      {
        "command": "claudePluginMarketplace.uninstallPlugin",
        "title": "%command.uninstallPlugin.title%"
      },
      {
        "command": "claudePluginMarketplace.updatePlugin",
        "title": "%command.updatePlugin.title%",
        "icon": "$(sync)"
      },
      {
        "command": "claudePluginMarketplace.showPluginDetails",
        "title": "%command.showPluginDetails.title%"
      },
      {
        "command": "claudePluginMarketplace.enablePlugin",
        "title": "%command.enablePlugin.title%"
      },
      {
        "command": "claudePluginMarketplace.disablePlugin",
        "title": "%command.disablePlugin.title%"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build-webview",
    "compile": "tsc -p ./ && tsc-alias",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:vscode": "npm run compile && node ./out/test/runTest.js",
    "test:vscode:grep": "npm run compile && node ./out/test/runTest.js --grep",
    "test:vscode:file": "npm run compile && node ./out/test/runTest.js --file",
    "build-webview": "cd webview && npx tsc && npx vite build && shx rm -rf dist/src && shx mv dist/sidebar.* dist/ 2>/dev/null || true",
    "dev-webview": "cd webview && npx vite"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.19.130",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.80.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vscode/test-electron": "^2.5.2",
    "autoprefixer": "^10.4.17",
    "glob": "^13.0.6",
    "jest": "^29.7.0",
    "mocha": "^11.7.5",
    "postcss": "^8.4.35",
    "shx": "^0.3.4",
    "tailwindcss": "^3.4.1",
    "terser": "^5.46.0",
    "ts-jest": "^29.4.6",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@types/yaml": "^1.9.6",
    "clsx": "^2.1.0",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^2.2.0",
    "yaml": "^2.8.2"
  }
}
