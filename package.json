{
  "name": "@claude-marketplace/plugin",
  "displayName": "Claude Plugin Marketplace",
  "description": "Claude Code 插件市场：浏览、安装、管理 Claude Code 技能插件",
  "version": "0.1.0",
  "publisher": "gdd-team",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "plugin",
    "marketplace",
    "skills"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-marketplace-sidebar",
          "title": "Plugin Market",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "claude-marketplace-sidebar": [
        {
          "id": "claudePluginMarketplaceSidebar",
          "type": "webview",
          "name": "插件市场"
        }
      ]
    },
    "commands": [
      {
        "command": "claudePluginMarketplace.refresh",
        "title": "刷新插件列表",
        "icon": "$(refresh)"
      },
      {
        "command": "claudePluginMarketplace.addMarketplace",
        "title": "添加插件市场",
        "icon": "$(add)"
      },
      {
        "command": "claudePluginMarketplace.removeMarketplace",
        "title": "删除插件市场"
      },
      {
        "command": "claudePluginMarketplace.refreshMarketplace",
        "title": "刷新插件市场"
      },
      {
        "command": "claudePluginMarketplace.installPlugin",
        "title": "安装插件"
      },
      {
        "command": "claudePluginMarketplace.uninstallPlugin",
        "title": "卸载插件"
      },
      {
        "command": "claudePluginMarketplace.updatePlugin",
        "title": "更新插件",
        "icon": "$(sync)"
      },
      {
        "command": "claudePluginMarketplace.showPluginDetails",
        "title": "查看插件详情"
      },
      {
        "command": "claudePluginMarketplace.enablePlugin",
        "title": "启用插件"
      },
      {
        "command": "claudePluginMarketplace.disablePlugin",
        "title": "禁用插件"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run build-webview",
    "compile": "tsc -p ./ && tsc-alias",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build-webview": "cd webview && npx tsc && npx vite build && shx rm -rf dist/src && shx mv dist/sidebar.* dist/ 2>/dev/null || true",
    "dev-webview": "cd webview && npx vite"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^18.19.130",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.80.0",
    "@vitejs/plugin-react": "^4.2.0",
    "jest": "^29.7.0",
    "shx": "^0.3.4",
    "ts-jest": "^29.4.6",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@types/yaml": "^1.9.6",
    "antd": "^6.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "yaml": "^2.8.2"
  }
}
