# Source files
src/**
tsconfig.json

# Build files (keep out/)
out/**
!out/extension.js
!out/extension.js.map
!out/pluginMarketplace/types.js
!out/pluginMarketplace/types.js.map
!out/pluginMarketplace/data/*.js
!out/pluginMarketplace/data/*.js.map
!out/pluginMarketplace/webview/*.js
!out/pluginMarketplace/webview/*.js.map
!out/pluginMarketplace/webview/messages/*.js
!out/pluginMarketplace/webview/messages/*.js.map
!out/pluginMarketplace/webview/services/*.js
!out/pluginMarketplace/webview/services/*.js.map
!out/pluginMarketplace/webview/utils/*.js
!out/pluginMarketplace/webview/utils/*.js.map
!out/shared/types/*.js
!out/shared/types/*.js.map
!out/shared/utils/*.js
!out/shared/utils/*.js.map
out/**/*.ts

# Tests
__tests__/**
__mocks__/**
jest.config.js
**/*.test.ts
**/*.test.tsx
**/*.spec.ts

# Webview source (keep dist/)
webview/**
!webview/dist/**

# Dependencies
node_modules/**
.vscode-extension/**

# Development & configs
.gitignore
.eslintrc*
.prettierrc*
.vscode-test/**
.vscode/**
.idea/**
.claude/**
.codex/**
screenshot/**

# Documentation (keep CHANGELOG.md for Marketplace)
docs/**
CLAUDE.md
TESTING.md
**/*.md
!README.md
!CHANGELOG.md

# Misc
*.vsix
.DS_Store
Thumbs.db

# Compiled test artifacts inside out/
out/**/__tests__/**
out/**/*.test.js
out/**/*.test.js.map
out/**/*.spec.js
out/**/*.spec.js.map
