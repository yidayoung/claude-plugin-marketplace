{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "label": "vscode: tsc"
    },
    {
      "type": "shell",
      "command": "npx tsc-alias -w -p tsconfig.json",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "label": "vscode: tsc-alias",
      "problemMatcher": [
        {
          "pattern": {
            "regexp": "^(.*)$",
            "file": 1,
            "location": 2,
            "message": 3
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": "Watching for file changes|Starting compilation"
          }
        }
      ]
    },
    {
      "label": "vscode: watch",
      "dependsOrder": "parallel",
      "dependsOn": [
        "vscode: tsc",
        "vscode: tsc-alias"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "dev-webview",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "label": "webview: dev server",
      "problemMatcher": [
        {
          "pattern": {
            "regexp": "^(.*)$",
            "file": 1,
            "location": 2,
            "message": 3
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": "Local:.*http.*|ready in \\d+ ms"
          }
        }
      ]
    },
    {
      "label": "vscode: watch with webview dev server",
      "dependsOrder": "parallel",
      "dependsOn": [
        "webview: dev server",
        "vscode: watch"
      ],
      "problemMatcher": []
    },
    {
      "type": "npm",
      "script": "compile",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent"
      },
      "label": "vscode: compile"
    },
    {
      "type": "npm",
      "script": "build-webview",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent"
      },
      "label": "vscode: build-webview"
    },
    {
      "label": "vscode: 全部构建",
      "dependsOrder": "sequence",
      "dependsOn": [
        "vscode: compile",
        "vscode: build-webview"
      ],
      "problemMatcher": []
    },
    {
      "label": "🛑 停止开发服务器",
      "type": "shell",
      "command": "npx --yes kill-port --port 5173",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always"
      },
      "detail": "手动停止 Vite 开发服务器 (端口 5173)"
    }
  ]
}
