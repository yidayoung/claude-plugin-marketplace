{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "path": "vscode-extension",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "vscode: watch"
    },
    {
      "label": "vscode: watch with webview",
      "dependsOrder": "parallel",
      "dependsOn": [
        "vscode: build-webview",
        "vscode: watch"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "并行任务：监听 Extension 代码变化 + Webview 热更新"
    },
    {
      "type": "npm",
      "script": "compile",
      "path": "vscode-extension",
      "problemMatcher": "$tsc",
      "presentation": {
        "reveal": "silent"
      },
      "group": "build",
      "label": "vscode: compile"
    },
    {
      "type": "npm",
      "script": "build-webview",
      "path": "vscode-extension",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent"
      },
      "group": "build",
      "label": "vscode: build-webview"
    },
    {
      "label": "vscode: 全部构建",
      "dependsOrder": "sequence",
      "dependsOn": [
        "vscode: compile",
        "vscode: build-webview"
      ],
      "problemMatcher": [],
      "group": "build"
    },
    {
      "type": "npm",
      "script": "dev-webview",
      "path": "vscode-extension",
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "label": "webview: dev server",
      "detail": "启动 Vite 开发服务器（热更新）"
    }
  ]
}
