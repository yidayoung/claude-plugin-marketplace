{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🔥 开发模式 (双端热更新 + 断点)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "vscode: watch with webview dev server",
      "resolveSourceMapLocations": [
        "${workspaceFolder}/out/**/*.js",
        "${workspaceFolder}/webview/src/**",
        "${workspaceFolder}/node_modules/**/*.js"
      ],
      "sourceMaps": true,
      "smartStep": true,
      "skipFiles": [
        "<node_internals>/**"
      ],
      "env": {
        "VITE_DEV_SERVER": "true",
        "NODE_ENV": "development"
      }
    },
    {
      "name": "✅ 生产模式 (完整构建)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js",
        "${workspaceFolder}/webview/dist/**/*.js"
      ],
      "preLaunchTask": "vscode: 全部构建",
      "resolveSourceMapLocations": [
        "${workspaceFolder}/out/**/*.js",
        "${workspaceFolder}/webview/dist/**/*.js"
      ]
    }
  ]
}
