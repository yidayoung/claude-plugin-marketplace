{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🔴 开发模式",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-extension/out/**/*.js"
      ],
      "preLaunchTask": "vscode: watch with webview"
    },
    {
      "name": "✅ 生产模式",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-extension/out/**/*.js"
      ],
      "preLaunchTask": "vscode: 全部构建"
    },
    {
      "name": "🌐 Webview 开发服务器",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev-webview"],
      "cwd": "${workspaceFolder}/vscode-extension",
      "console": "integratedTerminal",
      "presentation": {
        "hidden": false,
        "group": "webview"
      }
    }
  ]
}
