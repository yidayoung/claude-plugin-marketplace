{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🔴 开发模式 (Webview热更新)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-extension/out/**/*.js"
      ],
      "env": {
        "VSCODE_DEBUG_MODE": "true"
      },
      "preLaunchTask": "vscode: watch"
    },
    {
      "name": "✅ 生产模式 (快捷键正常)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-extension/out/**/*.js"
      ],
      "preLaunchTask": "vscode: 全部构建"
    },
    {
      "name": "🌐 Vite Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/vscode-extension/webview",
      "console": "integratedTerminal"
    },
  ]
}
